{
	"compilerOptions": {
		"composite": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"importHelpers": true,
		"isolatedModules": true,
		"lib": ["es2022"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"noEmitOnError": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "es2022",
		"customConditions": ["@frontend/source"],
		"baseUrl": ".",
		"paths": {
			"@frontend/plugin": ["plugin/src/index.ts"],
			"@frontend/shared/ui": ["libs/shared/ui/src/index.ts"],
			"@frontend/shared/utils": ["libs/shared/utils/src/index.ts"],
			"@frontend/shared/types": ["libs/shared/types/src/index.ts"],
			"@frontend/shared/config": ["libs/shared/config/src/index.ts"],
			"@frontend/shared/hooks": ["libs/shared/hooks/src/index.ts"],
			"@frontend/shared/constants": ["libs/shared/constants/src/index.ts"],
			"@frontend/shared/validations": ["libs/shared/validations/src/index.ts"],
			"@frontend/features/dashboard": ["libs/features/dashboard/src/index.ts"],
			"@frontend/features/mobile": ["libs/features/mobile/src/index.ts"],
			"@frontend/data/api": ["libs/data/api/src/index.ts"],
			"@frontend/data/store": ["libs/data/store/src/index.ts"],
			"@frontend/data/queries": ["libs/data/queries/src/index.ts"]
		}
	}
}
