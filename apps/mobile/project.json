{
	"name": "@frontend/mobile",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/mobile/src",
	"projectType": "application",
	"targets": {
		"build": {
			"executor": "@nx/expo:build",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/apps/mobile"
			}
		},
		"serve": {
			"executor": "@nx/expo:serve",
			"options": {}
		},
		"export": {
			"executor": "@nx/expo:export",
			"options": {
				"buildTarget": "@frontend/mobile:build"
			}
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
			"options": {
				"jestConfig": "apps/mobile/jest.config.ts",
				"passWithNoTests": true
			},
			"configurations": {
				"ci": {
					"ci": true,
					"coverageReporters": ["text"]
				}
			}
		},
		"biome-lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "biome lint apps/mobile"
			}
		},
		"biome:check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "biome check apps/mobile"
			}
		},
		"biome:format": {
			"executor": "nx:run-commands",
			"options": {
				"command": "biome format apps/mobile"
			}
		},
		"typecheck": {
			"executor": "@nx/js:tsc",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/apps/mobile",
				"main": "apps/mobile/src/app/App.tsx",
				"tsConfig": "apps/mobile/tsconfig.json",
				"assets": ["apps/mobile/assets/**/*"]
			}
		}
	},
	"tags": ["type:app", "scope:mobile"]
}
